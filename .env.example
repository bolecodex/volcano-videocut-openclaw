# 复制为 .env 后填写真实值（.env 勿提交到 Git）

# 火山引擎方舟 API Key（视频分析、OpenClaw 相关脚本等）
ARK_API_KEY=

# Seedance 2.0：在方舟控制台创建的「推理接入点」ID（形如 ep-xxxx）
SEEDANCE_MODEL=

# 可选：若 Seedance 使用单独 Key，填写此项；不填则与 ARK_API_KEY 相同
# SEEDANCE_API_KEY=

# 可选：多模态分析等使用的模型接入点（默认见各脚本）
# ARK_MODEL_NAME=

# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ── 技能「火山 AI MediaKit（VOD）」— 见 skills/volcengine-ai-mediakit/
# 来源：https://clawhub.ai/volc-ai-mediakit/volcengine-ai-mediakit
# VOLCENGINE_ACCESS_KEY=
# VOLCENGINE_SECRET_KEY=
# VOD_SPACE_NAME=
# 可选：VOLCENGINE_REGION、VOLCENGINE_HOST
