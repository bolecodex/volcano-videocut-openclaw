# =============================================================================
# 复制为 .env 后填写；勿将 .env 提交到 Git。
# 说明：多数技能会 load_dotenv(项目根/.env)；少数技能读自己目录下的 .env（见各 SKILL.md）。
# Electron「设置」弹窗仅同步部分键（见 electron/main.js 的 ENV_KEYS），其余请在本文件手写。
# =============================================================================

# ── 1) 方舟 / 内置剪辑与分析（scripts/*.py、video-analyzer、video-censor 等）──
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL_NAME=
# 可选：Seedance 单独 Key；不填则与 ARK_API_KEY 相同
# SEEDANCE_API_KEY=
# Seedance 2.0 推理接入点 ID（形如 ep-xxxx 或控制台展示的模型名，与脚本一致即可）
SEEDANCE_MODEL=

# ── 2) 应用内 AI 解说 / 兼容 TTS 占位（ai_narration.py）──
# ARK_TTS_ENDPOINT=
# ARK_TTS_MODEL=

# ── 3) ClawHub「火山 AI MediaKit（VOD）」skills/volcengine-ai-mediakit/ ──
# VOLCENGINE_ACCESS_KEY=
# VOLCENGINE_SECRET_KEY=
# VOD_SPACE_NAME=
# VOLCENGINE_REGION=cn-north-1
# VOLCENGINE_HOST=
# VOD_POLL_INTERVAL=5
# VOD_POLL_MAX=360

# ── 4) agentkit：Seedance / Seedream 脚本可选用独立 Key（不填则用 ARK_*）──
# MODEL_VIDEO_API_KEY=
# MODEL_VIDEO_API_BASE=
# MODEL_VIDEO_NAME=
# MODEL_AGENT_API_KEY=
# MODEL_IMAGE_API_KEY=
# MODEL_IMAGE_API_BASE=

# ── 5) agentkit：LAS 视频剪辑 / ASR-Pro / 音频切分 ──
# LAS_API_KEY=
# LAS_REGION=cn-beijing

# ── 6) agentkit：豆包语音（语音转文字 / TTS）skills/byted-voice-to-text、byted-text-to-speech ──
# MODEL_SPEECH_API_KEY=
# MODEL_SPEECH_APP_ID=
# MODEL_SPEECH_ASR_RESOURCE_ID=volc.bigasr.auc_turbo
# MODEL_SPEECH_TTS_RESOURCE_ID=seed-tts-2.0
# MODEL_SPEECH_API_BASE=openspeech.bytedance.com
# 飞书语音消息（可选）
# FEISHU_TENANT_TOKEN=
# 兼容：从方舟技能网关取 Key（可选）
# ARK_SKILL_API_KEY=
# ARK_SKILL_API_BASE=

# ── 7) GenSong 歌曲生成 skills/song-production/（脚本亦可能读 scripts/.env）──
# VOLC_ACCESS_KEY_ID=
# VOLC_ACCESS_KEY_SECRET=
# VOLC_REGION=cn-beijing
# VOLC_SERVICE=imagination

# ── 8) MV 制作 skills/mv-production/scripts/（常在该目录 .env 配置，根目录同名变量亦可备用）──
# VIDEO_API_URL=https://ark.cn-beijing.volces.com/api/v3/contents/generations/tasks
# VIDEO_MODEL=doubao-seedance-1-5-pro-251215
# ARK_IMAGE_API_URL=
# ARK_IMAGE_MODEL=
# OUTPUT_DIR=

# ── 9) 漫剧 skills/motion-comics-production（jimeng.js 读根或技能 .env）──
# TTS_APPID=
# TTS_TOKEN=
# TTS_CLUSTER=volcano_tts

# ── 10) KTV 歌词 skills/ktv-video-production/ ──
# DOUBAO_SPEECH_API_KEY=

# ── 11) 视频去敏 skills/video-redaction/（敏感词检测用 LLM；ASR 可用火山）──
# LLM_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o
# VOLCENGINE_API_KEY=

# ── 12) 可选：OpenClaw 诊断脚本 skills/byted-openclaw-diag/ ──
# DIAG_LOG=/tmp/openclaw/openclaw.log
# DIAG_SESSIONS_DIR=
# DIAG_AGENT_FILTER=

# ── 13) 其它 ──
# WORKSPACE=（MediaKit 上传白名单用 cwd，一般不必设）
# FFMPEG_CUT_AUTO_TRIM=0
# FFMPEG_CUT_AUTO_COMPRESS=0

# ── 历史/兼容占位（若你接火山旧版 ASR 文档可填）──
# VOLC_ASR_APPID=
# VOLC_ASR_TOKEN=
